+{
+  const rootIdx = process.argv.indexOf('--root')
+  if (rootIdx > 0) {
+    const rootValue = process.argv[rootIdx + 1]
+    process.argv.splice(rootIdx, rootValue && !rootValue.startsWith('-') ? 2 : 1)
+    if (rootValue && !rootValue.startsWith('-')) {
+      process.argv.push(rootValue)
+    }
+  }
